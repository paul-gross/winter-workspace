# Local-only winter config (git identity, machine-specific overrides)
/.winter/config.local.toml

# Machine-local env-index registry — never committed (tracks index assignments per machine)
/.winter/state.toml
/.winter/workflows/
/.winter/retrospectives/

# Auto-managed by `winter ws init` — extension list imported from AGENTS.md
/AGENTS.winter.md

# User/machine-specific overrides imported from AGENTS.md
/AGENTS.local.md

# Machine-specific winter-service-tmux overrides (overlaid on setup-tmux.sh)
/context/project/setup-tmux.local.sh
/context/project/workflow.local.sh

